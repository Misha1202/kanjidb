{
  "name": "kanjidb-desktop",
  "version": "1.0.0",
  "description": "Японские иероглифы и слова",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.kanjidb.app",
    "productName": "KanjiDB",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "files": [
      "main.js",
      "index.html",
      "preload.js"
    ]
  }
}